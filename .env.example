# Airtel Money credentials & configuration.
# Copy this file to `.env` and fill in your values. NEVER commit the real .env.

# Required
AIRTEL_CLIENT_ID=your-client-id
AIRTEL_CLIENT_SECRET=your-client-secret

# Optional: "staging" (default) or "production"
AIRTEL_ENVIRONMENT=staging

# Optional: explicit base URL (overrides AIRTEL_ENVIRONMENT).
# Staging:    https://openapiuat.airtel.africa
# Production: https://openapi.airtel.africa
# Uganda:     https://openapiuat.airtel.ug / https://openapi.airtel.ug
# AIRTEL_BASE_URL=https://openapiuat.airtel.ug

# Optional header defaults
AIRTEL_COUNTRY=UG
AIRTEL_CURRENCY=UGX
